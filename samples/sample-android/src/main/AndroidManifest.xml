<manifest xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Required by FrameDecorator overlay window (test Overlay Window button). -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <application
        android:name=".DemoApplication"
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            tools:ignore="RedundantLabel">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".TraceTestsActivity"
            android:exported="false"
            android:label="@string/trace_tests_title" />
        <activity
            android:name=".AnrTestActivity"
            android:exported="false"
            android:label="@string/anr_activity_title" />
        <activity
            android:name=".EvilMethodTestActivity"
            android:exported="false"
            android:label="@string/evil_activity_title" />
        <activity
            android:name=".FpsTestActivity"
            android:exported="false"
            android:label="@string/fps_activity_title" />
        <activity
            android:name=".IoTestActivity"
            android:exported="false"
            android:label="@string/io_activity_title" />
        <activity
            android:name=".LeakActivity"
            android:exported="false"
            android:label="@string/leak_activity_title" />

        <activity
            android:name=".TestHooksActivity"
            android:exported="false"
            android:label="@string/hooks_activity_title" />
        <activity
            android:name=".TestBatteryActivity"
            android:exported="false"
            android:label="@string/battery_activity_title" />
        <activity
            android:name=".TestSqliteLintActivity"
            android:exported="false"
            android:label="@string/sqlite_activity_title" />
        <activity
            android:name=".TestTrafficActivity"
            android:exported="false"
            android:label="@string/traffic_activity_title" />

        <service
            android:name=".SupervisorStubService"
            android:exported="false" />
    </application>
</manifest>
